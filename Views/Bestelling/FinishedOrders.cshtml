@model List<Chapeau.Models.Bestelling>

<a asp-action="RunningOrders" class="btn btn-primary">Running Orders</a>

<h1>Finished Orders</h1>

<table class="table">
    <thead>
        <tr>
            <th>Order</th>
            <th>Tafel</th>
            <th>Status</th>
            <th>Tijd</th>
            <th>Actie</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.Bestelling_ID</td>
                <td>@order.TafelNummer</td>
                <td>@order.Bestelling_Status</td>
                <td>@order.Datum_Tijd</td>

                <td>
                    @if (order.Bestelling_Status == "gereed")
                    {
                        <form asp-action="UpdateOrderStatus" method="post">
                            <input type="hidden" name="bestellingId" value="@order.Bestelling_ID" />
                            <input type="hidden" name="status" value="geserveerd" />

                            <button type="submit" class="btn btn-success">Markeer als geserveerd</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>