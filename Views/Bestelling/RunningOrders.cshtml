@model List<Chapeau.Models.Bestelling>

<div class="mt-4">

    <h1 class="mb-3">Running Orders</h1>

    <form method="get" class="mb-3">
        <button type="submit" class="btn btn-primary">Refresh</button>
    </form>

    <div class="card shadow-sm">
        <div class="card-body p-0">

            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Bestelling</th>
                        <th>Tafel</th>
                        <th>Status</th>
                        <th>Order tijd</th>
                        <th>Wachttijd</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.Bestelling_ID</td>
                            <td>@order.TafelNummer</td>
                            <td>@order.Bestelling_Status</td>
                            <td>@order.Datum_Tijd</td>
                            <td>@order.Wachttijd minuten</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>