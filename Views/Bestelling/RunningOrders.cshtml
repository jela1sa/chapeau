@model List<Chapeau.Models.Bestelling>


<a asp-action="FinishedOrders" class="btn btn-secondary">Finished Orders</a>


<h1>Running Orders</h1>

<a asp-action="RunningOrders" asp-route-type="all" class="btn btn-primary">Alles</a>

<a asp-action="RunningOrders" asp-route-type="kitchen" class="btn btn-warning">Keuken</a>

<a asp-action="RunningOrders" asp-route-type="bar" class="btn btn-info">Bar</a>

<form method="get"><button type="submit">Refresh</button></form>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Order</th>
            <th>Tafel</th>
            <th>Status</th>
            <th>Tijd</th>
            <th>Wachttijd</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.Bestelling_ID</td>
                <td>@order.TafelNummer</td>

                <td>
                    <strong>@order.Bestelling_Status</strong>

                    <form asp-action="UpdateOrderStatus" method="post">
                     <input type="hidden" name="bestellingId" value="@order.Bestelling_ID" />

                        <select name="status">
                            <option value="besteld">besteld</option>
                            <option value="in_bereiding">in_bereiding</option>
                            <option value="gereed">gereed</option>
                            <option value="geserveerd">geserveerd</option>
                        </select>

                        <button type="submit">OK</button>
                    </form>
                </td>

                <td>@order.Datum_Tijd</td>
                <td>@order.Wachttijd min</td>
            </tr>

            <tr>
                <td colspan="5">
                    @foreach (var categorie in order.BestellingsRondes
                                    .Where(x => x.MenuItem != null)
                                    .GroupBy(x => x.MenuItem.Categorie))
                    {
                        <h5>@categorie.Key</h5>                                                     
                        <form asp-action="UpdateCourseStatus" method="post">

                            <input type="hidden"
                                   name="bestellingId"
                                   value="@order.Bestelling_ID" />

                            <input type="hidden"
                                   name="categorie"
                                   value="@categorie.Key" />

                            <select name="status">
                                <option value="open">open</option>
                                <option value="in_bereiding">in_bereiding</option>
                                <option value="gereed">gereed</option>
                            </select>

                            <button type="submit">Update categorie</button>
                        </form>

                        <ul>
                            @foreach (var item in categorie)
                            {
                                <li>
                                    @item.Aantal x @item.MenuItem.Naam
                                    (<strong>@item.BestellingsRonde_Status</strong>)

                                    @if (!string.IsNullOrEmpty(item.Opmerkingen))
                                    {
                                        <span> - @item.Opmerkingen</span>
                                    }

                                    <form asp-action="UpdateItemStatus" method="post">
                                        <input type="hidden"
                                               name="bestellingsRondeId"
                                               value="@item.BestellingsRonde_ID" />

                                        <select name="status">
                                            <option value="open">open</option>
                                            <option value="gereed">gereed</option>
                                            <option value="in_bereiding">in_bereiding</option>
                                        </select>

                                        <button type="submit">Update item</button>
                                    </form>
                                </li>
                            }
                        </ul>
                    }


                </td>
            </tr>
        }
    </tbody>
</table>