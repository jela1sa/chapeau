@{
	ViewData["Title"] = "overview tables";
}

<div class="table-grid">
	@foreach (var Table in Model)
	{
		<div class="table-card">

			<div class="status-circle @(Table.status ? "red" : "green")"></div>

			<div class="table-number">
				@Table.tafel_nummer
			</div>

			<a href="/Table/Edit/@Table.tafel_ID" class="button">
				Edit
			</a>

		</div>
	}
</div>
