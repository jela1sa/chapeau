@{
    ViewData["Title"] = "Acount";
    Medewerker? loggedInMedewerker = (Medewerker?)ViewData["LoggedInMedewerker"];
}
<h1>Mijn Account</h1>


<p>
    Naam:
    @User.FindFirst("FullName")?.Value
</p>

<p>
    Rol:
    @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
</p>

<p>
    Gebruikersnaam:
    @User.Identity.Name
</p>
<form action="/Login/Logoff" method="post">

    <button type="submit"
            class="btn btn-danger">
        Logout
    </button>

</form>
