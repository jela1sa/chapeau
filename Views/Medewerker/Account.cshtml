@{
    ViewData["Title"] = "Acount";
    Medewerker? loggedInMedewerker = (Medewerker?)ViewData["LoggedInMedewerker"];
}
<h1>My Account</h1>

@if (loggedInMedewerker != null)
{
    <div class="card p-3">
        <p>ID: @loggedInMedewerker.bediening_ID</p>
        <p>Name: @loggedInMedewerker.naam</p>
        <p>Role: @loggedInMedewerker.rol</p>
        <p>Username: @loggedInMedewerker.gebruikersnaam</p>
    </div>


}
else
{
    <div class="alert alert-danger">
        No logged in user found.
    </div>
}
<form action="/Login/Logoff" method="post">

    <button type="submit"
            class="btn btn-danger">
        Logout
    </button>

</form>
