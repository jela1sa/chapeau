@page
@model Chapeau.ViewModels.PaymentViewModel
@{
    ViewBag.Title = "Payment Overview";
}

<h2>Table @Model.TableId</h2>

<table class="table">
    <thead>
        <tr>
            <th>Item</th>
            <th>Quantity</th>
            <th>Price</th>
            <th>Total</th>
            <th>VAT</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Quantity</td>
                <td>€ @item.PricePerItem.ToString("0.00")</td>
                <td>€ @item.TotalPrice.ToString("0.00")</td>
                <td>@item.VatRate %</td>
            </tr>
        }
    </tbody>
</table>

<hr />

<div>
    <h3>Total: € @Model.TotalAmount.ToString("0.00")</h3>

    <p>
        Low VAT Total:
        € @Model.LowVatTotal.ToString("0.00")
    </p>

    <p>
        High VAT Total:
        € @Model.HighVatTotal.ToString("0.00")
    </p>
</div>
