
@model Chapeau.ViewModels.RekeningViewModel
@{
    ViewData["Title"] = "Afrekenen";
}
    <h2>Rekening afrekenen</h2>

    <form asp-action="Afrekenen" method="post">
        <input type="hidden" asp-for="Bestelling_ID" />

    <div>
        <label>Tafel:</label>
        <select asp-for="Tafel_ID" asp-items="Model.TafelLijst" required>
            <option value="">-- Selecteer een tafel --</option>
        </select>
    </div>
        <div>
            <label>Totaalbedrag (€):</label>
            <input asp-for="TotaalBedrag" type="number" step="0.01" required />
        </div>

        <div>
            <label>Fooi (€):</label>
            <input asp-for="Fooi" type="number" step="0.01" value="0" />
        </div>

        <div>
            <label>Betaalwijze:</label>
            <select asp-for="Betaalwijze">
                <option value="creditcard">Creditcard</option>
                <option value="debitcard">Pin</option>
                <option value="cash">Contant</option>
            </select>
        </div>

        <div>
            <label>Feedback:</label>
            <textarea asp-for="Feedback"></textarea>
        </div>

        <button type="submit">Betaling bevestigen</button>
    </form>

